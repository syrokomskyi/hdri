{
	"name": "@org/pipeline-ai",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./src/index.ts",
	"scripts": {
		"build": "pnpm exec tsc -p tsconfig.lib.json",
		"lint": "pnpm exec eslint src --ext .ts",
		"typecheck": "pnpm exec tsc -p tsconfig.lib.json --noEmit",
		"upgrade-packages": "pnpm up --latest"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"@org/source": "./src/index.ts",
			"types": "./src/index.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./json": {
			"@org/source": "./src/lib/normalize-ai-json.ts",
			"types": "./src/lib/normalize-ai-json.ts",
			"import": "./dist/lib/normalize-ai-json.js",
			"default": "./dist/lib/normalize-ai-json.js"
		},
		"./openai": {
			"@org/source": "./src/lib/openai.ts",
			"types": "./src/lib/openai.ts",
			"import": "./dist/lib/openai.js",
			"default": "./dist/lib/openai.js"
		}
	},
	"files": [
		"dist",
		"!**/*.tsbuildinfo"
	],
	"dependencies": {
		"@org/pipeline-core": "workspace:*",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@anthropic-ai/sdk": "^0.100.1",
		"openai": "^6.39.1"
	}
}
