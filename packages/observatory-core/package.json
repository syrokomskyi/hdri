{
  "name": "@org/observatory-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm exec vitest run",
    "lint": "pnpm exec eslint src --ext .ts"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ontology": {
      "@org/source": "./src/ontology/index.ts",
      "types": "./src/ontology/index.ts",
      "import": "./dist/ontology/index.js",
      "default": "./dist/ontology/index.js"
    },
    "./hashing": {
      "@org/source": "./src/hashing.ts",
      "types": "./src/hashing.ts",
      "import": "./dist/hashing.js",
      "default": "./dist/hashing.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
