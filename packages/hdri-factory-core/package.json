{
  "name": "@org/hdri-factory-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.lib.json",
    "lint": "pnpm exec eslint src --ext .ts",
    "typecheck": "pnpm exec tsc -p tsconfig.lib.json --noEmit",
    "upgrade-packages": "pnpm up --latest"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@org/business-core": "workspace:*",
    "@org/observatory-crypto": "workspace:*",
    "@org/observatory-emit": "workspace:*",
    "@org/pipeline-core": "workspace:*",
    "@org/pipeline-node": "workspace:*",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1"
  }
}
