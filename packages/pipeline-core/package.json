{
  "name": "@org/pipeline-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.lib.json",
    "lint": "pnpm exec eslint src --ext .ts",
    "typecheck": "pnpm exec tsc -p tsconfig.lib.json --noEmit",
    "upgrade-packages": "pnpm up --latest"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./phase": {
      "@org/source": "./src/lib/pipeline-phase.ts",
      "types": "./src/lib/pipeline-phase.ts",
      "import": "./dist/lib/pipeline-phase.js",
      "default": "./dist/lib/pipeline-phase.js"
    },
    "./step": {
      "@org/source": "./src/lib/pipeline-step.ts",
      "types": "./src/lib/pipeline-step.ts",
      "import": "./dist/lib/pipeline-step.js",
      "default": "./dist/lib/pipeline-step.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
