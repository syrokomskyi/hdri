---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

type Props = {
  title: string;
  description: string;
  canonical?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown>;
};

const { title, description, canonical, noIndex = false, schema } = Astro.props;
const site = 'https://handwerk-index.org';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site).href;
const robotsContent = noIndex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="text/plain" title="LLMs" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full" href="/llms-full.txt" />
    <link rel="alternate" type="text/plain" title="AI Policy" href="/ai.txt" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...schema })} />
    )}
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>
