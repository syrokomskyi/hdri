---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import SiteHeader from '../components/SiteHeader.astro';

type Props = {
  title: string;
  description: string;
  canonical?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown>;
  image?: string;
};

const { title, description, canonical, noIndex = false, schema, image = '/og-image.webp' } = Astro.props;
const site = 'https://handwerk-index.org';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site).href;
const imageUrl = new URL(image, site).href;
const robotsContent = noIndex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <link rel="alternate" type="text/plain" title="LLMs" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="LLMs Full" href="/llms-full.txt" />
    <link rel="alternate" type="text/plain" title="AI Policy" href="/ai.txt" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', ...schema })} />
    )}
  </head>
  <body>
    <SiteHeader>
      <!-- Forward the page "header-extra" slot into the header "extra" slot -->
      <slot name="header-extra" slot="extra" />
    </SiteHeader>
    <slot />
    <Footer />
  </body>

  <script>
    import Lenis from 'lenis';

    const lenis = new Lenis({ duration: 1.1, smoothWheel: true });

    // Smooth scroll for anchors: intercept all clicks on <a href="#...">
    document.addEventListener('click', (e) => {
      const a = (e.target as Element).closest('a[href^="#"]');
      if (!a) return;
      const hash = a.getAttribute('href');
      if (!hash || hash === '#') return;
      let target: Element | null;
      try { target = document.querySelector(hash); } catch { return; }
      if (!target) return;
      e.preventDefault();
      // Subtract sticky header height so the target is not hidden behind it
      const header = document.querySelector<HTMLElement>('.site-header');
      const offset = header ? -(header.offsetHeight + 8) : -8;
      lenis.scrollTo(target as HTMLElement, { offset, duration: 1.1 });
    });

    function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  </script>
</html>
