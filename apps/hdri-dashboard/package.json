{
  "name": "@org/hdri-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "export:data": "pnpm --filter @org/digital-observatory run export:dashboard",
    "build": "astro build",
    "start": "astro dev",
    "dev": "astro dev",
    "preview": "pnpm --dir ../.. exec astro preview --root apps/hdri-dashboard",
    "typecheck": "pnpm --dir ../.. exec astro sync --root apps/hdri-dashboard && pnpm --dir ../.. exec tsc -p apps/hdri-dashboard/tsconfig.json --noEmit",
    "upgrade-packages": "pnpm up --latest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.0",
    "astro": "^6.4.2",
    "d3-array": "^3.2.4",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "katex": "^0.17.0",
    "lenis": "^1.3.23",
    "topojson-client": "^3.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/node": "^25.9.1",
    "terser": "^5.48.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
